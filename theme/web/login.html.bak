<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    {{themecss}} {{appicons}} {{manifest}} {{startupimages}}
    <link rel="stylesheet" href="./login.css">
    <link rel="stylesheet" href="./media-queries.css">
</head>

<body>
    <div class="mx-scrollcontainer-wrapper">
        <div data-mx-placeholder="f24a271c-597d-46a6-b097-7b334b8481c7" class="mx-placeholder">
            <img class="siemens-logo" src="./img/logoSiemensWhite48.svg" />
            <div class="version-details">
                <div class="version-number">Version 2310</div>
                <br>
                <div class="version-text">This material contains trade secrets or otherwise confidential information
                    owned by Siemens Industry Software Inc. or its affiliates (collectively, “Siemens”), or its
                    licensors. Access to and use of this information is strictly limited as set forth in the Customer’s
                    applicable agreements with Siemens.
                </div>
                <div class="version-copyright">Unpublished work. &#169 2023 Siemens.</div>
            </div>
            <div class="login-background">
                <div class="mx-layoutgrid mx-layoutgrid-fluid container-fluid">
                    <div class="row">
                        <div class="col-md-12 col-sm-12 col-xs-12 login-left-column ">
                            <div class="login-left-wrapper">
                                <div class="app-form">
                                    <form id="loginForm" autocomplete="off">
                                        <div class="login-header">
                                            <div class="product-logo-container">
                                                <div class="teal-box"></div>
                                                <img class="product-logo" src="./appOcEx32.svg" role="presentation" />
                                            </div>
                                            <div>
                                                <div class="system-name">OPCENTER EXECUTION</div>
                                                <div class="product-name">Medical Device & Diagnostics</div>
                                            </div>
                                        </div>
                                        <div>
                                            <div id="loginMessage" class="alert alert-danger"></div>
                                            <div class="form-group">
                                                <div class="label-container">
                                                    <div class="teal-asterisk">*</div>
                                                    <label class="control-label" id="usernameLabel"
                                                        for="usernameInput"></label>
                                                </div>
                                                <div class="inputwrapper">
                                                    <input id="usernameInput" class="form-control" type="text"
                                                        autocorrect="off" autocapitalize="none" autocomplete="off" />
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <div class="label-container">
                                                    <div class="teal-asterisk">*</div>
                                                    <label class="control-label" id="passwordLabel"
                                                        for="passwordInput"></label>
                                                </div>
                                                <div class="inputwrapper">
                                                    <input id="passwordInput" class="form-control" type="password"
                                                        autocorrect="off" autocapitalize="none" autocomplete="off" />
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <div class="label-container">
                                                    <div class="teal-asterisk">*</div>
                                                    <label class="control-label" id="domainLabel"
                                                        for="domainInput">Domain</label>
                                                </div>
                                                <div class="inputwrapper">
                                                    <input id="domainInput" class="form-control" type="text"
                                                        autocorrect="off" autocapitalize="none" autocomplete="off" />
                                                </div>
                                            </div>
                                            <div class="form-toolbar">
                                                <button id="loginButton1" type="button" class="btn btn-primary"
                                                    disabled>
                                                    Log In
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
    <script>
        let usernameInput = document.getElementById("usernameInput");
        let passwordInput = document.getElementById("passwordInput");
        let domainInput = document.getElementById("domainInput");
        let loginButton = document.getElementById("loginButton1");
        let usernameLabel = document.getElementById("usernameLabel");
        let passwordLabel = document.getElementById("passwordLabel");
        let domainLabel = document.getElementById("domainLabel");
        let asterisks = document.querySelectorAll('.teal-asterisk');

        usernameLabel.innerHTML = "User Name";
        usernameInput.setAttribute("placeholder", "");
        passwordLabel.innerHTML = "Password";
        passwordInput.setAttribute("placeholder", "");
        loginButton.innerHTML = 'Log In';

        function inputChangeHandler() {
            if (usernameInput.value === '' || passwordInput.value === '' || domainInput.value === '') {
                loginButton.disabled = true;
            } else {
                loginButton.disabled = false;
            }
        }

        function usernameInputChangeHandler() {
            inputChangeHandler();
            usernameInput.classList.remove('login-error');
            usernameLabel.classList.remove('login-error');
            asterisks[0].classList.remove('login-error');
            usernameLabel.innerHTML = "User Name";
        }

        function passwordInputChangeHandler() {
            inputChangeHandler();
            passwordInput.classList.remove('login-error');
            passwordLabel.classList.remove('login-error');
            asterisks[1].classList.remove('login-error');
            passwordLabel.innerHTML = "Password";
        }

        function domainInputChangeHandler() {
            inputChangeHandler();
            domainInput.classList.remove('login-error');
            domainLabel.classList.remove('login-error');
            asterisks[2].classList.remove('login-error');
            domainLabel.innerHTML = "Domain";
        }

        usernameInput.addEventListener('input', usernameInputChangeHandler);
        passwordInput.addEventListener('input', passwordInputChangeHandler);
        domainInput.addEventListener('input', domainInputChangeHandler);

        function formSubmitHandler() {
            var xhr = new XMLHttpRequest();
            var url = "/v1/opcenterLogin";
            xhr.open("POST", url, true);
            xhr.setRequestHeader("Content-Type", "application/json");
            xhr.onreadystatechange = opcenterLoginHandler(xhr);
            var data = JSON.stringify({
                "Username": usernameInput.value,
                "Password": passwordInput.value,
                "Domain": domainInput.value,
                "ServerURL": ""
            });
            xhr.send(data);
        }

        function loginErrorHandler() {
            usernameInput.classList.add('login-error');
            passwordInput.classList.add('login-error');
            domainInput.classList.add('login-error');
            usernameLabel.classList.add('login-error');
            passwordLabel.classList.add('login-error');
            domainLabel.classList.add('login-error');
            asterisks.forEach((element) => {
                element.classList.add('login-error');
            });
            usernameLabel.innerHTML = "User Name (Wrong Credentials)"
            passwordLabel.innerHTML = "Password (Wrong Credentials)";
            domainLabel.innerHTML = "Domain (Wrong Credentials)";
        }

        function opcenterLoginHandler(xhr) {
            return function () {
                if (xhr.readyState === 4) {
                    console.log(xhr.response);
                    if (xhr.status === 200) {
                        var xhr2 = new XMLHttpRequest();
                        var url = "/v1/mendixLogin";
                        xhr2.open("POST", url, true);
                        xhr2.setRequestHeader("Content-Type", "application/json");
                        xhr2.onreadystatechange = mendixLoginHandler(xhr2);
                        var data = JSON.stringify({
                            "Username": usernameInput.value,
                            "Password": passwordInput.value,
                            "Domain": domainInput.value,
                            "ServerURL": ""
                        });
                        xhr2.send(data);
                    } else if (xhr.status === 401) {
                        loginErrorHandler();
                    }
                }
            }
        };

        function mendixLoginHandler(xhr) {
            return function () {
                if (xhr.readyState === 4) {
                    console.log(xhr.response);
                    if (xhr.status === 200) {
                        window.location.replace("./index.html");
                    }
                }
            }
        };

        loginButton.addEventListener('click', formSubmitHandler);
    </script>
</body>

</html>